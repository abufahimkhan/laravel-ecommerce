# ============================================
# Fast Basket - Root Environment Variables
# ============================================

# Application
APP_NAME="Fast Basket"
APP_ENV=local
APP_URL=http://localhost
APP_PORT=80
APP_KEY=

# PostgreSQL
DB_CONNECTION=pgsql
DB_HOST=database
DB_PORT=5432
DB_DATABASE=app_db
DB_USERNAME=app_user
DB_PASSWORD=secret123

# Redis
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=null

# Cache, Queue, Session
CACHE_STORE=redis
QUEUE_CONNECTION=redis
SESSION_DRIVER=redis
SESSION_LIFETIME=120

# Mailpit (catches emails in dev)
MAIL_MAILER=smtp
MAIL_HOST=mailpit
MAIL_PORT=1025
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=null
MAIL_FROM_ADDRESS="noreply@fastbasket.com"
MAIL_FROM_NAME="${APP_NAME}"

# pgAdmin
PGADMIN_EMAIL=admin@fastbasket.com
PGADMIN_PASSWORD=admin123

# Next.js
NEXT_PUBLIC_API_URL=http://localhost/api
